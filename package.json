{
  "name": "ovms-auth-gateway",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -n web,worker -c magenta,yellow \"npm:dev:web\" \"npm:dev:worker\"",
    "dev:web": "next dev",
    "dev:worker": "tsx watch workers/generationWorker.ts",
    "build": "next build && tsc -p tsconfig.worker.json",
    "start": "next start",
    "worker": "tsx workers/generationWorker.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.3",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.4.7",
    "ioredis": "^5.11.0",
    "mongodb": "^6.14.2",
    "next": "^15.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
